__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ─── 前端 ─────────────────────────────────────
node_modules/
dist/
.turbo/

