# ═══ 风控引擎决策分析平台 — 环境变量模板 ═══
# 复制此文件为 .env 并填入真实配置
# ⚠️ .env 文件已加入 .gitignore，不会上传到仓库

# 环境
ENV=dev
DEBUG=true

# StarRocks 风险数据库
STARROCKS_HOST=localhost
STARROCKS_PORT=9030
STARROCKS_USER=
STARROCKS_PASSWORD=
STARROCKS_DATABASE=

# MySQL 淘顺分期
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# API
API_HOST=0.0.0.0
API_PORT=8000
